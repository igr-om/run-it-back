# Copy this file to .env and fill in real values before deploying anywhere
# besides your own machine. docker-compose.yml reads JWT_SECRET from your
# shell/.env automatically; DATABASE_URL there is hardcoded to the bundled
# Postgres service, so you usually don't need to set it yourself for local
# Docker Compose use.

# --- required in production ---
# A long, random string. Generate one with: openssl rand -hex 32
JWT_SECRET=change-me-please-this-is-not-secure

# --- database ---
# Local Docker Compose sets this automatically; only needed if you're
# running the server binary directly (not via docker-compose) or pointing
# at a managed Postgres (RDS, Supabase, Neon, Fly Postgres, Render Postgres...).
DATABASE_URL=postgres://runitback:runitback@localhost:5432/runitback

# --- server ---
PORT=8080
# Number of dynamic worker threads (parsing + solving). 0 = number of CPUs.
RIB_WORKERS=0
# Pre-solve the curated preflop spot library on startup (recommended).
RIB_WARM_LIBRARY_ON_START=1
# Set automatically by the Docker image; only needed if you build the
# frontend separately and want the Rust binary to serve it.
# STATIC_DIR=/app/static
